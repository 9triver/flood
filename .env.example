# OpenAI-compatible LLM service. Required for agent reasoning and chat.
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=
LLM_DISABLE_REASONING=true

# AMap Web Service key. Required for evacuation route planning.
AMAP_WEB_SERVICE_KEY=
# AMAP_WEB_SERVICE_URL=https://restapi.amap.com
# AMAP_TIMEOUT_SECONDS=20

# Optional runtime tuning.
FLOOD_AGENT_MAX_TURNS=10
FLOOD_CNN_TIMEOUT_SECONDS=300
FLOOD_WORKSPACE_RETENTION_COUNT=3
# FLOOD_BOUNDARY_FLOW_CSV=/absolute/path/to/boundary_flow.csv
# FLOOD_CNN_PYTHON=/absolute/path/to/python
